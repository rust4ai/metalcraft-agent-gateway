# Gateway auth — clients must send this as Bearer token (required)
AGENT_GATEWAY_API_KEY=change-me

# Discord (set to enable Discord support)
DISCORD_BOT_TOKEN=

# Slack (set to enable Slack support)
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=

# GitHub webhook verification (HMAC-SHA256)
GITHUB_WEBHOOK_SECRET=

# Subscriber database path (default: ./gateway.db)
GATEWAY_DB_PATH=./gateway.db

# Server
PORT=3000
RUST_LOG=info
