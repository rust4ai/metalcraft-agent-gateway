# Gateway auth — clients must send this as Bearer token (required)
AGENT_GATEWAY_API_KEY=change-me

# Discord (set to enable Discord support)
DISCORD_BOT_TOKEN=

# Slack (set to enable Slack support)
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=

# GitHub webhook verification (HMAC-SHA256)
GITHUB_WEBHOOK_SECRET=

# WhatsApp via Twilio (set TWILIO_ACCOUNT_SID to enable).
# Inbound: point your Twilio WhatsApp sender's webhook at
#   POST https://<host>/gateway/api/v1/webhooks/twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=+14155238886          # your Twilio WhatsApp number (E.164)
# Optional: exact public webhook URL — enables X-Twilio-Signature verification.
TWILIO_WEBHOOK_URL=
# Optional allowlist: only these numbers may reach the agent (comma-separated,
# E.164). Leave blank to allow all (the daemon still gates via admin user IDs).
TWILIO_ALLOWED_NUMBERS=

# Subscriber database path (default: ./gateway.db)
GATEWAY_DB_PATH=./gateway.db

# Server
PORT=3000
RUST_LOG=info
