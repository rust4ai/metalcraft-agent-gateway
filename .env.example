# Default platform when requests omit the "platform" field.
# If only one token is set, that platform is used automatically.
PLATFORM=discord

# Gateway auth — clients must send this as Bearer token
AGENT_GATEWAY_API_KEY=change-me

# Discord (set to enable Discord support)
DISCORD_BOT_TOKEN=

# Slack (set to enable Slack support)
SLACK_BOT_TOKEN=

# Server
PORT=3000
RUST_LOG=info
